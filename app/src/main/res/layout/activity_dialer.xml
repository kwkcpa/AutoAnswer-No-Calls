<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:padding="16dp">

    <!-- Top bar with settings -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="16dp">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:text="Auto Answer Dialer" android:textSize="20sp" android:textStyle="bold" android:textColor="#1A1A1A" />
        <ImageButton android:id="@+id/btnSettings" android:layout_width="48dp" android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_preferences" android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Settings" />
    </LinearLayout>

    <!-- Phone number display -->
    <EditText android:id="@+id/editPhoneNumber" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:textSize="32sp" android:textColor="#1A1A1A" android:gravity="center" android:inputType="phone"
        android:background="@null" android:hint="Enter number" android:layout_marginBottom="16dp" />

    <!-- Dial pad grid -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
        android:orientation="vertical" android:gravity="center">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center" android:layout_marginBottom="8dp">
            <com.google.android.material.button.MaterialButton android:id="@+id/btn1" style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="80dp" android:layout_height="64dp" android:text="1" android:textSize="24sp" android:layout_margin="4dp" />
            <com.google.android.material.button.MaterialButton android:id="@+id/btn2" style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="80dp" android:layout_height="64dp" android:text="2" android:textSize="24sp" android:layout_margin="4dp" />
            <com.google.android.material.button.MaterialButton android:id="@+id/btn3" style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="80dp" android:layout_height="64dp" android:text="3" android:textSize="24sp" android:layout_margin="4dp" />
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center" android:layout_marginBottom="8dp">
            <com.google.android.material.button.MaterialButton android:id="@+id/btn4" style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="80dp" android:layout_height="64dp" android:text="4" android:textSize="24sp" android:layout_margin="4dp" />
            <com.google.android.material.button.MaterialButton android:id="@+id/btn5" style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="80dp" android:layout_height="64dp" android:text="5" android:textSize="24sp" android:layout_margin="4dp" />
            <com.google.android.material.button.MaterialButton android:id="@+id/btn6" style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="80dp" android:layout_height="64dp" android:text="6" android:textSize="24sp" android:layout_margin="4dp" />
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center" android:layout_marginBottom="8dp">
            <com.google.android.material.button.MaterialButton android:id="@+id/btn7" style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="80dp" android:layout_height="64dp" android:text="7" android:textSize="24sp" android:layout_margin="4dp" />
            <com.google.android.material.button.MaterialButton android:id="@+id/btn8" style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="80dp" android:layout_height="64dp" android:text="8" android:textSize="24sp" android:layout_margin="4dp" />
            <com.google.android.material.button.MaterialButton android:id="@+id/btn9" style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="80dp" android:layout_height="64dp" android:text="9" android:textSize="24sp" android:layout_margin="4dp" />
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center" android:layout_marginBottom="8dp">
            <com.google.android.material.button.MaterialButton android:id="@+id/btnStar" style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="80dp" android:layout_height="64dp" android:text="*" android:textSize="24sp" android:layout_margin="4dp" />
            <com.google.android.material.button.MaterialButton android:id="@+id/btn0" style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="80dp" android:layout_height="64dp" android:text="0" android:textSize="24sp" android:layout_margin="4dp" />
            <com.google.android.material.button.MaterialButton android:id="@+id/btnHash" style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="80dp" android:layout_height="64dp" android:text="#" android:textSize="24sp" android:layout_margin="4dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Call and delete buttons -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center" android:layout_marginTop="8dp" android:layout_marginBottom="16dp">
        <View android:layout_width="80dp" android:layout_height="1dp" android:layout_margin="4dp" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btnCall"
            android:layout_width="80dp" android:layout_height="64dp" android:text="Call"
            android:textSize="16sp" app:cornerRadius="32dp" android:backgroundTint="#4CAF50"
            android:layout_margin="4dp" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btnDelete"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="80dp" android:layout_height="64dp" android:text="DEL"
            android:textSize="16sp" android:layout_margin="4dp" />
    </LinearLayout>
</LinearLayout>
